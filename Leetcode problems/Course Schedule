import java.util.*;

class Solution {
    public boolean canFinish(int numCourses, int[][] prerequisites) {
        // 1. Build the adjacency list graph and calculate the in-degrees
        List<List<Integer>> adj = new ArrayList<>();
        for (int i = 0; i < numCourses; i++) {
            adj.add(new ArrayList<>());
        }
        
        int[] inDegree = new int[numCourses];
        for (int[] pre : prerequisites) {
            int course = pre[0];
            int prerequisite = pre[1];
            adj.get(prerequisite).add(course);
            inDegree[course]++;
        }
        
        // 2. Add all courses with 0 prerequisites (in-degree == 0) to the queue
        Queue<Integer> queue = new LinkedList<>();
        for (int i = 0; i < numCourses; i++) {
            if (inDegree[i] == 0) {
                queue.offer(i);
            }
        }
        
        // 3. Process the queue and keep a count of courses we can take
        int takenCoursesCount = 0;
        while (!queue.isEmpty()) {
            int current = queue.poll();
            takenCoursesCount++;
            
            // "Take" the course and reduce the in-degree of its dependent courses
            for (int neighbor : adj.get(current)) {
                inDegree[neighbor]--;
                // If a neighbor now has 0 prerequisites left, we can take it next
                if (inDegree[neighbor] == 0) {
                    queue.offer(neighbor);
                }
            }
        }
        
        // 4. If we were able to take all courses, there's no cycle
        return takenCoursesCount == numCourses;
    }
}
