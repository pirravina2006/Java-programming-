class Solution {
    public int rob(int[] nums) {
        if(nums.length==0){
            return 0;
        }
        if(nums.length==1){
            return nums[0];
        }
        int p1=0;
        int p2=nums[0];
        if(p2>nums[1]){
            p1=p2;
        }
        else{
            p1=nums[1];
        }
        int c=0;
        for(int i=2;i<nums.length;i++){
            c=Math.max(p1,(nums[i]+p2));
            p2=p1;
            p1=c;
        }
        return p1;
    }
}
