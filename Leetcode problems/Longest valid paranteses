class Solution {
    public int longestValidParentheses(String s) {
        if(s==null || s.length()==0){
            return 0;
        }
        int n=s.length();
        int []arr=new int[n+1];
        int high=-1;
        int mlen=0;
        arr[++high]=-1;
        for(int i=0;i<n;i++){
            if(s.charAt(i)=='('){
                arr[++high]=i;
            }
            else{
                high--;
                if(high==-1){
                    arr[++high]=i;
                }
                else{
                    mlen=Math.max(mlen,i-arr[high]);
                }
            }
        }
        return mlen;
    }
}
